   17          void Timer_Delay_us(u16 us)
   18          {
   19   1          u32 start, current, elapsed;
   20   1          // ВЮЪ§ЗЖЮЇМьВщ
   21   1          if (us == 0 || us > 1000) 
   22   1          {
   23   2              us = 1;  // ФЌШЯзюаЁ1us
   24   2          }
   25   1          
   26   1          start = (u16)T3H << 8 + T3L;  // ЖСШЁЕБЧАМЦЪ§жЕ
   27   1          
   28   1          // ВщбЏЗНЪНЕШД§
   29   1          while (1)
   30   1          {
   31   2              current = (u16)T3H << 8 + T3L;
   32   2              
   33   2              // ДІРэМЦЪ§ЦївчГі
   34   2              if (current >= start) 
   35   2              {
   36   3                  elapsed = current - start;
   37   3              } 
   38   2              else 
   39   2              {
   40   3                  elapsed = (0xFFFF - start) + current + 1;
   41   3              }
   42   2              
   43   2              if (elapsed >= us) 
   44   2              {
   45   3                  break;
   46   3              }
   47   2          }
   48   1      }
