  164   1          u32 start, current, elapsed;
  165   1          // ВЮЪ§ЗЖЮЇМьВщ
  166   1          if (us == 0 || us > 1000) 
  167   1          {
  168   2              us = 1;  // ФЌШЯзюаЁ1us
  169   2          }
  170   1          
  171   1          start = (u16)T3H << 8 + T3L;  // ЖСШЁЕБЧАМЦЪ§жЕ
  172   1          
  173   1          // ВщбЏЗНЪНЕШД§
  174   1          while (1)
  175   1          {
  176   2              current = (u16)T3H << 8 + T3L;
  177   2              
  178   2              // ДІРэМЦЪ§ЦївчГі
  179   2              if (current >= start) 
  180   2              {
  181   3                  elapsed = current - start;
  182   3              } 
  183   2              else 
  184   2              {
