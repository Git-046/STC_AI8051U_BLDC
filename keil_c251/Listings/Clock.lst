  107          //========================================================================
  108          void HSPllClkConfig(u8 clksrc, u8 pllsel, u8 div)
  109          {
  110   1              //系统时钟选择, MCLKSEL_HIRC/MCLKSEL_XIRC/MCLKSEL_X32K/MCLKSEL_I32K/MCLKSEL_PLL/MCLKSEL_PLL2/MCLKSEL_I48
             -M
  111   1          MainClockSel(clksrc);
  112   1      
  113   1          //系统时钟 n 分频作为PLL时钟源,确保分频后为12M
  114   1          USBCLK &= ~PCKI_MSK;
  115   1      #if (MAIN_Fosc == 12000000UL)
                   USBCLK |= PCKI_D1;          //PLL输入时钟1分频
