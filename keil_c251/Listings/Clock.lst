    9          /*---------------------------------------------------------------------------------
   10          @ function  :   void Clock_Init(void)
   11          @ describe  :   时钟初始化函数
   12          @ parameter :   None
   13          @ date      :   2026-2-25
   14          -----------------------------------------------------------------------------------*/
   15          void Clock_Init(void)
   16          {
   17   1          Clock_Struct xdata clock_struct;
   18   1          memset((void*)&clock_struct, 0, sizeof(Clock_Struct));
   19   1          
   20   1          clock_struct.Main_clock_source = MCKSEL_HIRC;   //主时钟源选择      MCKSEL_HIRC(40MHz)
   21   1          clock_struct.IRC_en = ENABLE;                   //使能对应的时钟源
   22   1          clock_struct.Main_clock_div = 1;                //主时钟源分频
   23   1          clock_struct.PLL_select = PLL_SEL;              //PLL频率选择
   24   1          clock_struct.HSIO_select = HSCK_PLL;            //高速IO时钟源选择             144MHz
   25   1          clock_struct.HSIO_div = 1;                      //高速IO时钟分频               144MHz
   26   1          clock_struct.TFPU_div = 2;                      //TFPU对时钟源(HSIO)分频       72MHz
   27   1          clock_struct.PLL_en = ENABLE;                   //PLL倍频功能使能 
   28   1          clock_struct.PLL_source_div = 4;                //PLL的时钟源需要为12MHz(8~16MHz)
   29   1          clock_struct.PWMA_div = 2;                      //PWMA时钟源分频               72MHz
   30   1          clock_struct.PWMB_div = 1;                      //PWMB时钟源分频               144MHz
   31   1      }
   32          
   33          void Clock_Configuration(Clock_Struct xdata *clock_struct)
   34          {
   35   1          /*1. 主时钟选择*/
   36   1          CLKSEL &= ~0x0F | clock_struct->Main_clock_source;
   37   1          /*2. 使能时钟源 */
   38   1          HIRCCR &= ~0x80 | clock_struct->IRC_en;
   39   1          /*3. 对主时钟分频得到系统时钟 */
   40   1          CLKDIV = clock_struct->Main_clock_div;
   41   1          
   42   1          /*4. 其他时钟设置 */
   43   1          CLKSEL &= ~0x80 | clock_struct->PLL_select;         //PLL频率选择
   44   1          CLKSEL &= ~0x40 | clock_struct->HSIO_select;        //高速IO时钟源选择
   45   1          HSCLKDIV = clock_struct->HSIO_div;                  //高速IO时钟源分频
   46   1          TFPU_CLKDIV = 1;                                    //TFPU的时钟源分频
   47   1          USBCLK &= ~0x80 | clock_struct->PLL_en;             //PLL倍频功能使能
   48   1          USBCLK &= ~0x60 | clock_struct->PLL_source_div;     //PLL时钟源分频
   49   1          PWMA_CLKDIV = clock_struct->PWMA_div;               //PWMA时钟源分频
   50   1          PWMB_CLKDIV = clock_struct->PWMB_div;               //PWMB时钟源分频
   51   1      }
