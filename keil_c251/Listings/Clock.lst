   59          // 版本: V1.0, 2022-04-03
   60          //========================================================================
   61          void HIRCClkConfig(u8 div)
   62          {
   63   1          HIRCCR = 0x80;      //启动内部 IRC
   64   1          while (!(HIRCCR & 1)); //等待时钟稳定
   65   1          CLKDIV = div;
   66   1          CLKSEL = 0x00;      //选择内部 IRC ( 默认 )
   67   1      }
   68          
