               #else
  124   1          USBCLK |= PCKI_D4;          //默认PLL输入时钟4分频
  125   1      #endif
  126   1      
  127   1          PLLClockSel(pllsel);        //PLL时钟选择, PLL_96M/PLL_144M
  128   1          PLLEnable(ENABLE);          //PLL倍频使能, ENABLE/DISABLE
  129   1          delay_ms(1);                //等待PLL锁频
  130   1          HSIOClockSel(HSCK_PLL);     //高速IO时钟选择, HSCK_MCLK/HSCK_PLL
