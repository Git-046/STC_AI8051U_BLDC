             -beta_voltage->voltage_beta) / v_bus * T_pwm);
   99   1          z = (int16)(SQUARE_ROOT_3 * (-SQUARE_ROOT_3_DIVIDE2 * alpha_beta_voltage->voltage_alpha + 0.5 * alpha
             -_beta_voltage->voltage_beta) / v_bus * T_pwm);
