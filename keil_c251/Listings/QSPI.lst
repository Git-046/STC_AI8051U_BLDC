   63   1          QSPI_InstructionSingMode();     //设置指令为单线模式
   64   1          QSPI_NoAddress();               //无地址字节
   65   1              QSPI_NoAlternate();             //无间隔字节
   66   1          QSPI_DataSingMode();            //设置数据为单线模式
