    7          //========================================================================
    8          // 函数: u8 QSPI_Inilize(ADC_InitTypeDef *QSPI)
    9          // 描述: QSPI初始化程序.
   10          // 参数: QSPI: 结构参数,请参考头文件里的定义.
   11          // 返回: none.
   12          // 版本: V1.0, 2025-03-22
   13          //========================================================================
   14          u8 QSPI_Inilize(QSPI_InitTypeDef *QSPI)
   15          {
   16   1          if(QSPI->FIFOLevel > 31)    return FAIL;    //错误
   17   1          if(QSPI->FlashSize > 31)    return FAIL;    //错误
   18   1          if(QSPI->CSHold > 7)        return FAIL;    //错误
   19   1      
   20   1          while (QSPI_CheckBusy());       //检测忙状态
   21   1      
   22   1          QSPI_SetFIFOLevel(QSPI->FIFOLevel);         //设置FIFO阈值为(31+1)=32字节
   23   1          QSPI_SetClockDivider(QSPI->ClockDiv);       //设置QSPI时钟为系统时钟/(4+1)
   24   1          QSPI_SetCSHold(QSPI->CSHold);               //设置CS保持时间为(1+1)=2个QSPI时钟
   25   1      
   26   1          if(QSPI->CKMode)    QSPI_SetIdleCLKHigh();  //空闲时SCK为高电平
   27   1          else    QSPI_SetIdleCLKLow();               //空闲时SCK为低电平
   28   1      
   29   1          QSPI_SetFlashSize(QSPI->FlashSize);         //设置Flash大小为2^(25+1)=64M字节,
   30   1      
   31   1          if(QSPI->SIOO)    QSPI_InstructionOnce();   //设置仅第一条事务发送指令
   32   1          else    QSPI_InstructionAlways();           //设置每个事务均发送指令
   33   1      
   34   1          if(QSPI->QSPI_EN)    QSPI_Enable();         //使能QSPI
   35   1          else    QSPI_Disable();                     //禁止QSPI
   36   1      
   37   1          return SUCCESS;
   38   1      }
   39          
   40          void QSPI_WRITE_INSTR(BYTE cmd)
   41          {
   42   1          while (QSPI_CheckBusy());       //检测忙状态
   43   1      
   44   1          QSPI_SetWriteMode();            //写模式
   45   1          QSPI_SetDummyCycles(0);         //设置DUMMY时钟
   46   1          QSPI_InstructionSingMode();     //设置指令为单线模式
   47   1          QSPI_NoAddress();               //无地址字节
   48   1              QSPI_NoAlternate();             //无间隔字节
   49   1          QSPI_NoData();                  //无数据
   50   1          QSPI_SetInstruction(cmd);       //设置指令
   51   1      
   52   1          while (!QSPI_CheckTransfer());  //等到数据传输完成
   53   1          QSPI_ClearTransfer();           //清除传输完成标志
   54   1      }
