 1121   1          DMA_QSPI_AMTH = (datalen-1) >> 8;
 1122   1          DMA_QSPI_RXAH = (WORD)pdat >> 8;//设置DMA的存储器起始地址
 1123   1          DMA_QSPI_RXAL = (BYTE)pdat;     //设置DMA的存储器起始地址
 1124   1          DMA_QSPI_STA = 0x00;            //清除DMA状态
 1125   1          DMA_QSPI_CFG = 0x20;            //使能DMA读取操作
 1126   1          DMA_QSPI_CR = 0xa1;             //启动DMA并触发QSPI读操作
 1127   1          while (!(DMA_QSPI_STA & 0x01)); //等待DMA操作完成
 1128   1          DMA_QSPI_STA = 0x00;            //清除DMA状态
 1129   1          DMA_QSPI_CFG = 0x00;
 1130   1          DMA_QSPI_CR = 0x00;
 1131   1          QSPI_ClearTransfer();           //清除传输完成标志
 1132   1      }
 1133          
 1134          void QSPI_DMA_WRITE(BYTE *pdat, WORD datalen)
 1135          {
 1136   1          DMA_QSPI_AMT = datalen-1;       //设置DMA数据长度
 1137   1          DMA_QSPI_AMTH = (datalen-1) >> 8;
 1138   1          DMA_QSPI_TXAH = (WORD)pdat >> 8;//设置DMA的存储器起始地址
 1139   1          DMA_QSPI_TXAL = (BYTE)pdat;     //设置DMA的存储器起始地址
 1140   1          DMA_QSPI_STA = 0x00;            //清除DMA状态
 1141   1          DMA_QSPI_CFG = 0x40;            //使能DMA写操作
 1142   1          DMA_QSPI_CR = 0xc2;             //启动DMA并触发QSPI写操作
 1143   1          while (!(DMA_QSPI_STA & 0x01)); //等待DMA操作完成
 1144   1          DMA_QSPI_STA = 0x00;            //清除DMA状态
 1145   1          DMA_QSPI_CFG = 0x00;
 1146   1          DMA_QSPI_CR = 0x00;
 1147   1          QSPI_ClearTransfer();           //清除传输完成标志
 1148   1      }


