  345          //========================================================================
  346          // 函数: ReadPWMA(void)
  347          // 描述: 异步读取PWMA特殊功能寄存器函数. 
  348          // 参数: addr: 读取特殊功能寄存器地址.
  349          // 返回: dat:  读取特殊功能寄存器内容.
  350          // 版本: V1.0, 2022-03-16
  351          //========================================================================
  352          u8 ReadPWMA(u8 addr)
  353          {
  354   1              u8 dat;
  355   1              
  356   1              while (HSPWMA_ADR &     0x80); //等待前一个异步读写完成
  357   1              HSPWMA_ADR = addr |     0x80;  //设置间接访问地址,只需要设置原XFR地址的低7位
  358   1                                                                      //HSPWMA_ADDR寄存器的最高位写1,表示读数据
  359   1              while (HSPWMA_ADR &     0x80); //等待当前异步读取完成
  360   1              dat     = HSPWMA_DAT;              //读取异步数据
  361   1              
  362   1              return dat;
  363   1      }
  364          
