  369          // 返回: dat:  读取特殊功能寄存器内容.
  370          // 版本: V1.0, 2022-03-16
  371          //========================================================================
  372          u8 ReadPWMB(u8 addr)
  373          {
  374   1              u8 dat;
  375   1              
  376   1              while (HSPWMB_ADR &     0x80); //等待前一个异步读写完成
  377   1              HSPWMB_ADR = addr |     0x80;  //设置间接访问地址,只需要设置原XFR地址的低7位
  378   1                                                                      //HSPWMB_ADDR寄存器的最高位写1,表示读数据
  379   1              while (HSPWMB_ADR &     0x80); //等待当前异步读取完成
  380   1              dat     = HSPWMB_DAT;              //读取异步数据
  381   1              
  382   1              return dat;
  383   1      }
