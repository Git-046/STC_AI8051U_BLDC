    5          #include "LCM.h"
    6          
    7          //========================================================================
    8          // 函数: void LCM_Inilize(LCM_InitTypeDef *LCM)
    9          // 描述: LCM 初始化程序.
   10          // 参数: LCM: 结构参数,请参考LCM.h里的定义.
   11          // 返回: none.
   12          // 版本: V1.0, 2021-06-02
   13          //========================================================================
   14          void LCM_Inilize(LCM_InitTypeDef *LCM)
   15          {
   16   1          LCMIFSTA = 0x00;
   17   1          if(LCM->LCM_Mode == MODE_M6800) LCMIFCFG |= MODE_M6800;    //LCM接口模式：M6800
   18   1          else LCMIFCFG &= ~MODE_M6800;   //LCM接口模式：I8080
   19   1          
   20   1          if(LCM->LCM_Bit_Wide == BIT_WIDE_16) LCMIFCFG |= BIT_WIDE_16;   //LCM数据宽度：16位
   21   1          else LCMIFCFG &= ~BIT_WIDE_16;  //LCM数据宽度：8位
   22   1          
   23   1          if(LCM->LCM_Setup_Time <= 7) LCMIFCFG2 = (LCMIFCFG2 & ~0x1c) | (LCM->LCM_Setup_Time << 2);  //LCM通信
             -数据建立时间：0~7
   24   1          if(LCM->LCM_Hold_Time <= 3) LCMIFCFG2 = (LCMIFCFG2 & ~0x03) | LCM->LCM_Hold_Time;   //LCM通信数据建立
             -时间：0~7
   25   1          
   26   1          if(LCM->LCM_Enable == ENABLE) LCMIFCR |= 0x80;  //使能LCM接口功能
   27   1          else LCMIFCR &= ~0x80;    //禁止LCM接口功能
   28   1      }


