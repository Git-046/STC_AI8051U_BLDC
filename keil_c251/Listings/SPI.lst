   62          //========================================================================
   63          void SPI_Configuration(SPI_InitTypeDef *SPIx)
   64          {
   65   1         if(SPIx->SPI_SSIG == ENABLE) SSIG = 1;     //conform Master or Slave by SPI_Mode(ignore SS)
   66   1         else                         SSIG = 0;     //conform Master or Slave by SS pin.
   67   1         SPI_Start(SPIx->SPI_Enable);
   68   1         SPI_FirstBit_Set(SPIx->SPI_MSB_LSB);
   69   1         SPI_Mode_Set(SPIx->SPI_Master_Slave);
   70   1         SPI_CPOL_Set(SPIx->SPI_CPOL);
   71   1         SPI_CPHA_Set(SPIx->SPI_CPHA);
   72   1         SPI_Clock_Select(SPIx->SPI_Speed);
   73   1      
   74   1         if(SPIx->TimeOutScale == TO_SCALE_SYSCLK)   SPITOCR |= 0x20;  //і¬КұјЖКэКұЦУФҙЈәПөНіКұЦУ
   75   1         else
   76   1         {
   77   2             SET_TPS();          //ЙиЦГПөНіөИҙэКұјдөҘФӘЈ¬УГУЪҝШЦЖEEPROMІЩЧчЎўSPI/I2Cі¬КұКұјдТФј°РЭГЯ»ҪРСөИҙэКұј
             -д
   78   2             SPITOCR &= ~0x20;   //і¬КұјЖКэКұЦУФҙЈә1usКұЦУ(1MHzКұЦУ)
   79   2         }
   80   1      
   81   1         if((SPIx->TimeOutTimer > 0) && (SPIx->TimeOutTimer <= 0xffffff))
   82   1         {
   83   2             SPITOTL = (u8)SPIx->TimeOutTimer;
   84   2             SPITOTH = (u8)(SPIx->TimeOutTimer>>8);
   85   2             SPITOTE = (u8)(SPIx->TimeOutTimer>>16); //Рҙ SPITOTE әуЈ¬РВөДTMЦөІЕ»бЙъР§
   86   2         }
   87   1         
   88   1         if((SPIx->SPI_Master_Slave == SPI_Mode_Slave) && (SPIx->TimeOutEnable == ENABLE))
   89   1         {
   90   2             SPI_TimerOutEn = 1;
   91   2             SPITOCR |= 0x80;    //ҙУ»ъҪУКХі¬Кұ№ҰДЬК№ДЬ
   92   2         }
   93   1         else
   94   1         {
   95   2             SPI_TimerOutEn = 0;
   96   2             SPITOCR &= ~0x80;   //ҙУ»ъҪУКХі¬Кұ№ҰДЬҪыЦ№
   97   2         }
   98   1      
   99   1         if(SPIx->TimeOutINTEnable == ENABLE) SPITOCR |= 0x40;   //ҙУ»ъҪУКХі¬КұЦР¶ПК№ДЬ
  100   1         else                                 SPITOCR &= ~0x40;  //ҙУ»ъҪУКХі¬КұЦР¶ПҪыЦ№
  101   1      }
