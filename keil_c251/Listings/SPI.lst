  159          // 返回: none.
  160          // 版本: V1.0, 2020-09-14
  161          //========================================================================
  162          void SPI_WriteByte(u8 dat)  //SPI发送一个字节数据
  163          {
  164   1          if(ESPI)
  165   1          {
  166   2              B_SPI_Busy = 1;
  167   2              SPDAT = dat;
  168   2              while(B_SPI_Busy);  //中断模式
  169   2          }
  170   1          else
  171   1          {
  172   2              SPDAT = dat;
  173   2              while(SPIF == 0);   //查询模式
  174   2              SPI_ClearFlag();    //清除SPIF和WCOL标志
  175   2          }
  176   1      }
  177          
