  128          //========================================================================
  129          // 函数: void SPI_SetMode(u8 mode)
  130          // 描述: SPI设置主从模式函数.
  131          // 参数: mode: 指定模式, 取值 SPI_Mode_Master 或 SPI_Mode_Slave.
  132          // 返回: none.
  133          // 版本: V1.0, 2012-11-22
  134          //========================================================================
  135          void SPI_SetMode(u8 mode)
  136          {
  137   1          if(mode == SPI_Mode_Slave)
  138   1          {
  139   2              MSTR = 0;     //重新设置为从机待机
  140   2              SSIG = 0;     //SS引脚确定主从
  141   2              if(SPI_TimerOutEn)
  142   2              {
  143   3                  SPI_TOIFClear();
  144   3                  SPITOCR |= 0x80;    //从机接收超时功能使能
  145   3              }
  146   2          }
  147   1          else
  148   1          {
  149   2              SPITOCR &= ~0x80;   //从机接收超时功能禁止
  150   2              MSTR = 1;     //使能 SPI 主机模式
  151   2              SSIG = 1;     //忽略SS引脚功能
  152   2          }
  153   1      }
