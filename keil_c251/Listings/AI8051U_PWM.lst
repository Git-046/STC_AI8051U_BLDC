  201          u8 PWM_Configuration_2(u8 PWMx, PWMx_InitDefine *PWMx_InitStructure)
  202          {
  203   1              if(PWMx == PWM1)
  204   1              {
  205   2                      PWMA_CC1E_Disable();            //先关闭主通道的 输入捕获/比较输出
  206   2                      PWMA_CC1NE_Disable();           //先关闭互补通道的 比较输出
  207   2                      /* CCnS仅在通道关闭时才是可写的 */
  208   2                      
  209   2                      //1.如果PWM通道选择为输出通道模式
  210   2                      if(PWMx_InitStructure->PWM_Output_Channel_Select != 0x00)
  211   2                      {
  212   3                              PWMA_CC1S_Direction(PWMx_InitStructure->PWM_IO_Channel_Select); //设置 输出/ (输入)捕获方向
  213   3                              PWMA_OC1ModeSet(PWMx_InitStructure->PWM_OC_Mode);                               //设置比较/捕获模式
  214   3                              
  215   3                              /*1.1 主通道*/
  216   3                              if(PWMx_InitStructure->PWM_Output_Channel_Select & ENO1P)
  217   3                              {
  218   4                                      PWMA_CC1E_Enable();             //开启输入捕获/比较输出
  219   4                                      PWMA_ENO |= ENO1P;              //使能对应的PWM输出通道
  220   4                              }
  221   3                              else
  222   3                              {
  223   4                                      PWMA_CC1E_Disable();    //关闭输入捕获/比较输出
  224   4                                      PWMA_ENO &= ~ENO1P;             //失能对应的PWM输出通道
  225   4                              }
  226   3                              /*互补通道*/
  227   3                              if(PWMx_InitStructure->PWM_Output_Channel_Select & ENO1N)
  228   3                              {
  229   4                                      PWMA_CC1NE_Enable();            //开启输入捕获/比较输出
  230   4                                      PWMA_ENO |= ENO1N;
  231   4                              }
  232   3                              else
  233   3                              {
  234   4                                      PWMA_CC1NE_Disable();           //关闭输入捕获/比较输出
  235   4                                      PWMA_ENO &= ~ENO1N;
  236   4                              }
  237   3                              
  238   3                              /*1.2 根据结构体中PWM_Pin_Select选择的脚位自动配置寄存器 */
  239   3                              if(PWM_Pin_Configuration(PWMx, PWMx_InitStructure) == FALSE)
  240   3                              {
  241   4                                      printf("PWM_Pin_Configuration failed!\n");
  242   4                                      return FAIL;
  243   4                              }
  244   3                              /*1.3 设置输出比较*/
  245   3                              PWMA_OC1ModeSet(PWMx_InitStructure->PWM_OC_Mode);                               //输出比较模式
  246   3                              PWMA_OC1_ReloadEnable(PWMx_InitStructure->PWM_OC_PreLoad_EN);   //输出比较预装载使能位
  247   3                              
  248   3                              /*1.4 设置占空比初始值*/
  249   3                              PWMA_Duty1(PWMx_InitStructure->PWM_Duty);
  250   3                              
  251   3                              /*1.5 其他*/
  252   3                              PWMA_CCMR1 = (PWMA_CCMR1 & 0x80) | PWMx_InitStructure->PWM_EXTI_Clear_OC_Ref_EN;
  253   3                              PWMA_CCMR1 = (PWMA_CCMR1 & 0x04) | PWMx_InitStructure->PWM_Fast_EN;
  254   3                              return SUCCESS;
  255   3                      }
  256   2                      //2.如果PWM通道选择为输入捕获模式
C251 COMPILER V5.60.0,  AI8051U_PWM                                                        31/10/25  08:14:11  PAGE 5   

