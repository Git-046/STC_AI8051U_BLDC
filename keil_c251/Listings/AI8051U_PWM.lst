  605          //========================================================================
  606          // 函数: ReadPWMA(void)
  607          // 描述: 异步读取PWMA特殊功能寄存器函数. 
  608          // 参数: addr: 读取特殊功能寄存器地址.
  609          // 返回: dat:  读取特殊功能寄存器内容.
  610          // 版本: V1.0, 2022-03-16
  611          //========================================================================
  612          u8 ReadPWMA(u8 addr)
  613          {
  614   1              u8 dat;
  615   1              
  616   1              while (HSPWMA_ADR &     0x80); //等待前一个异步读写完成
  617   1              HSPWMA_ADR = addr |     0x80;  //设置间接访问地址,只需要设置原XFR地址的低7位
  618   1                                                                      //HSPWMA_ADDR寄存器的最高位写1,表示读数据
  619   1              while (HSPWMA_ADR &     0x80); //等待当前异步读取完成
  620   1              dat     = HSPWMA_DAT;              //读取异步数据
  621   1              
  622   1              return dat;
  623   1      }
  624          
