  638   1                                                                      //HSPWMB_ADDR寄存器的最高位写1,表示读数据
  639   1              while (HSPWMB_ADR &     0x80); //等待当前异步读取完成
  640   1              dat     = HSPWMB_DAT;              //读取异步数据
  641   1              
