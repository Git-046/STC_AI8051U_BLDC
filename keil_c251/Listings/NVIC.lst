  189          // 描述: 比较器嵌套向量中断控制器初始化.
  190          // 参数: State:    中断使能状态, RISING_EDGE/FALLING_EDGE/DISABLE.
C251 COMPILER V5.60.0,  NVIC                                                               03/03/26  16:23:12  PAGE 4   

  191          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  192          // 返回: 执行结果 SUCCESS/FAIL.
  193          // 版本: V1.0, 2020-09-29
  194          //========================================================================
  195          u8 NVIC_CMP_Init(u8 State, u8 Priority)
  196          {
  197   1              if(State & RISING_EDGE) PIE = 1;                        //允许上升沿中断
  198   1              else    PIE = 0;                        //禁止上升沿中断
  199   1              if(State & FALLING_EDGE)        NIE = 1;                //允许下降沿中断
  200   1              else    NIE = 0;                        //禁止上升沿中断
  201   1              if(Priority <= Priority_3) CMP_Priority(Priority); else  return FAIL;
  202   1              return SUCCESS;
  203   1      }
