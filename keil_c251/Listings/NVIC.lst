  359          //========================================================================
  360          // 函数: NVIC_DMA_ADC_Init
  361          // 描述: DMA ADC嵌套向量中断控制器初始化.
  362          // 参数: State:    中断使能状态, ENABLE/DISABLE.
  363          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  364          // 参数: Bus_Priority: 数据总线访问优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  365          // 返回: 执行结果 SUCCESS/FAIL.
  366          // 版本: V1.0, 2021-05-21
  367          //========================================================================
  368          u8 NVIC_DMA_ADC_Init(u8 State, u8 Priority, u8 Bus_Priority)
  369          {
  370   1              DMA_ADC_CFG &= ~0x0f;
  371   1              if(Priority <= Priority_3) DMA_ADC_CFG |= Priority << 2;
  372   1              if(Bus_Priority <= Priority_3) DMA_ADC_CFG |= Bus_Priority;     //数据总线访问优先级
  373   1              if(State == ENABLE)
  374   1                      DMA_ADC_CFG |= 0x80;            //bit7 1:Enable Interrupt
  375   1              else
  376   1                      DMA_ADC_CFG &= ~0x80;           //bit7 0:Disable Interrupt
  377   1              return SUCCESS;
  378   1      }
  379          
