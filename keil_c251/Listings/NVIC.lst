  322          // 描述: PWM嵌套向量中断控制器初始化.
  323          // 参数: Channel:  通道, PWMA/PWMB.
  324          // 参数: State:    中断使能状态, PWM_BIE/PWM_TIE/PWM_COMIE/PWM_CC8IE~PWM_CC1IE/PWM_UIE/DISABLE.
  325          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  326          // 返回: 执行结果 SUCCESS/FAIL.
  327          // 版本: V1.0, 2020-09-29
  328          //========================================================================
  329          #ifndef PWMA
  330          #define PWMA    9
  331          #endif
  332          #ifndef PWMB
  333          #define PWMB    10
  334          #endif
  335          u8 NVIC_PWM_Init(u8 Channel, u8 State, u8 Priority)
  336          {
  337   1              if(Channel > PWMB) return FAIL;
  338   1              if(Priority > Priority_3) return FAIL;
  339   1              switch(Channel)
  340   1              {
  341   2                      case PWMA:
  342   2                              PWMA_IER = State;
  343   2                              PWMA_Priority(Priority);
  344   2                      break;
  345   2      
  346   2                      case PWMB:
  347   2                              PWMB_IER = State;
  348   2                              PWMB_Priority(Priority);
  349   2                      break;
  350   2      
  351   2                      default:
  352   2                              PWMB_IER = State;
  353   2                              Priority = NONE;
  354   2                      break;
  355   2              }
  356   1              return SUCCESS;
  357   1      }
