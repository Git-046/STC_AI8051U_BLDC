  206          // 函数: NVIC_I2C_Init
  207          // 描述: I2C嵌套向量中断控制器初始化.
  208          // 参数: Mode:     模式, I2C_Mode_Master/I2C_Mode_Slave.
  209          // 参数: State:    中断使能状态, I2C_Mode_Master: ENABLE/DISABLE.
  210          //                              I2C_Mode_Slave: I2C_ESTAI/I2C_ERXI/I2C_ETXI/I2C_ESTOI/DISABLE.
  211          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  212          // 返回: 执行结果 SUCCESS/FAIL.
  213          // 版本: V1.0, 2020-09-29
  214          //========================================================================
  215          u8 NVIC_I2C_Init(u8 Mode, u8 State, u8 Priority)
  216          {
  217   1              if(Mode > 1) return FAIL;
  218   1              if(Mode == 1)   //I2C_Mode_Master
  219   1              {
  220   2                      I2C_Master_Inturrupt(State);
  221   2              }
  222   1              else if(Mode == 0)      //I2C_Mode_Slave
  223   1              {
  224   2                      I2CSLCR = (I2CSLCR & ~0x78) | State;
  225   2              }
  226   1              if(Priority <= Priority_3) CMP_Priority(Priority); else  return FAIL;
  227   1              return SUCCESS;
  228   1      }
