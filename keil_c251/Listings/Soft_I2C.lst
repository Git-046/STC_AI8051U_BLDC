   88          void I2C_WriteAbyte(u8 dat)     //write a byte to I2C
   89          {
   90   1              u8 i;
   91   1              i = 8;
   92   1              do
   93   1              {
   94   2                      if(dat & 0x80)  SDA = 1;
   95   2                      else            SDA = 0;
