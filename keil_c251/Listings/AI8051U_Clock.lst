   53          //========================================================================
   54          // 函数: void HSPllClkConfig(u8 clksrc, u8 pcki, u8 pllsel, u8 div)
   55          // 描述: 高速IO时钟初始化程序.
   56          // 参数: clksrc: 系统时钟选择, MCLKSEL_HIRC/MCLKSEL_XIRC/MCLKSEL_X32K/MCLKSEL_I32K/MCLKSEL_PLL/MCLKSEL_PL
             -L2/MCLKSEL_I48M.
   57          // 参数: pllsel: PLL时钟选择, PLL_96M/PLL_144M.
C251 COMPILER V5.60.0,  AI8051U_Clock                                                      31/10/25  08:14:11  PAGE 2   

   58          // 参数: div: 高速IO时钟分频系数.
   59          // 返回: none.
   60          // 版本: V1.0, 2022-04-03
   61          //========================================================================
   62          void HSPllClkConfig(u8 clksrc, u8 pllsel, u8 div)
   63          {
   64   1              //系统时钟选择, MCLKSEL_HIRC/MCLKSEL_XIRC/MCLKSEL_X32K/MCLKSEL_I32K/MCLKSEL_PLL/MCLKSEL_PLL2/MCLKSEL_I48
             -M
   65   1          MainClockSel(clksrc);
   66   1      
   67   1          //系统时钟 n 分频作为PLL时钟源,确保分频后为12M
   68   1          USBCLK &= ~PCKI_MSK;
   69   1      #if (MAIN_Fosc == 12000000UL)
                   USBCLK |= PCKI_D1;          //PLL输入时钟1分频
               #elif (MAIN_Fosc == 24000000UL)
                   USBCLK |= PCKI_D2;          //PLL输入时钟2分频
               #elif (MAIN_Fosc == 48000000UL)
                   USBCLK |= PCKI_D4;          //PLL输入时钟4分频
               #elif (MAIN_Fosc == 96000000UL)
                   USBCLK |= PCKI_D8;          //PLL输入时钟8分频
               #else
   78   1          USBCLK |= PCKI_D4;          //默认PLL输入时钟4分频
   79   1      #endif
   80   1      
   81   1          PLLClockSel(pllsel);        //PLL时钟选择, PLL_96M/PLL_144M
   82   1          PLLEnable(ENABLE);          //PLL倍频使能, ENABLE/DISABLE
   83   1          delay_ms(1);                //等待PLL锁频
   84   1          HSIOClockSel(HSCK_PLL);     //高速IO时钟选择, HSCK_MCLK/HSCK_PLL
   85   1          HSClockDiv(div);            //高速IO时钟分频系数
   86   1              
   87   1              //2025.10.21
   88   1      //      DMAIR = 0x3E;   //选择 系统时钟 作为TFPU时钟源
   89   1              DMAIR = 0x3F;   //选择 PLL时钟  作为TFPU时钟源
   90   1              TFPU_CLKDIV = 2;        //TFPU工作频率要求低于108MHz
   91   1      }


