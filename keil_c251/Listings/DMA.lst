             -CHANNEL_2;//ADC0、ADC1、ADC2、ADC3
   19   1              DMA_ADC_InitStructure.DMA_Buffer_Address = (u16)&ADC_Result_Buffer[0];  //设定DMA存放ADC数据的地址
