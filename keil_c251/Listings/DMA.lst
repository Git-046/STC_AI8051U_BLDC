   57          // 版本: V1.0, 2021-05-17
   58          //========================================================================
   59          void DMA_ADC_Inilize(DMA_ADC_InitTypeDef xdata *DMA)
   60          {
   61   1              DMA_ADC_STA = 0x00;
   62   1              DMA_ADC_CHSW1 = (u8)(DMA->DMA_Channel>>8);
   63   1              DMA_ADC_CHSW0 = (u8)(DMA->DMA_Channel);
   64   1              DMA_ADC_RXAH = (u8)(DMA->DMA_Buffer_Address>>8);
   65   1              DMA_ADC_RXAL = (u8)(DMA->DMA_Buffer_Address);
   66   1              DMA_ADC_CFG2 = DMA->DMA_Times;  //设定每一个通道的重复扫描次数
   67   1              
   68   1              DMA_ADC_AMT = DMA->DMA_Scan_Times;
   69   1              DMA_ADC_AMTH = DMA->DMA_Scan_Times >> 8;        //设定通道循环扫描次数
   70   1              
   71   1              if(DMA->DMA_Enable == ENABLE)
   72   1              {
   73   2                      DMA_ADC_CR |= 0x80;     //使能ADC DMA
   74   2              }
   75   1              else DMA_ADC_CR &= ~0x80;       //禁止ADC DMA
   76   1      }
