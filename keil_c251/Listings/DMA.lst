   15          // 函数: void DMA_ADC_Inilize(DMA_ADC_InitTypeDef *DMA)
   16          // 描述: DMA ADC 初始化程序.
   17          // 参数: DMA: 结构参数,请参考DMA.h里的定义.
   18          // 返回: none.
   19          // 版本: V1.0, 2021-05-17
   20          //========================================================================
   21          void DMA_ADC_Inilize(DMA_ADC_InitTypeDef xdata *DMA)
   22          {
   23   1              DMA_ADC_STA = 0x00;
   24   1              DMA_ADC_CHSW1 = (u8)(DMA->DMA_Channel>>8);
   25   1              DMA_ADC_CHSW0 = (u8)(DMA->DMA_Channel);
   26   1              DMA_ADC_RXAH = (u8)(DMA->DMA_Buffer_Address>>8);
   27   1              DMA_ADC_RXAL = (u8)(DMA->DMA_Buffer_Address);
   28   1              DMA_ADC_CFG2 = DMA->DMA_Times;  //设定每一个通道的重复扫描次数
   29   1              
   30   1              DMA_ADC_AMT = DMA->DMA_Scan_Times;
   31   1              DMA_ADC_AMTH = DMA->DMA_Scan_Times >> 8;        //设定通道循环扫描次数
   32   1              
   33   1              if(DMA->DMA_Enable == ENABLE)
   34   1              {
   35   2                      DMA_ADC_CR |= 0x80;     //使能ADC DMA
   36   2              }
   37   1              else DMA_ADC_CR &= ~0x80;       //禁止ADC DMA
   38   1      }
