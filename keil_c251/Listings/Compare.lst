    5          #include "Compare.h"
    6          
    7          //========================================================================
    8          // 函数:void CMP_Inilize(CMP_InitDefine *CMPx)
    9          // 描述: 比较器初始化程序.
   10          // 参数: CMPx: 结构参数,请参考compare.h里的定义.
   11          // 返回: none.
   12          // 版本: V1.0, 2012-10-22
   13          //========================================================================
   14          void CMP_Inilize(CMP_InitDefine *CMPx)
   15          {
   16   1          CMPCR1 &= 0x30;
   17   1          CMPCR2 = CMPx->CMP_OutDelayDuty & 0x3f;                 //比较结果变化延时周期数, 0~63
   18   1          if(CMPx->CMP_EN == ENABLE)              CMPEN = 1;      //允许比较器        ENABLE,DISABLE
   19   1          if(CMPx->CMP_Outpt_En == ENABLE)        CMPOE = 1;      //允许比较结果输出到P3.4/P4.1,   ENABLE,DISAB
             -LE
   20   1          if(CMPx->CMP_InvCMPO     == ENABLE)     INVCMPO = 1;    //比较器输出取反,   ENABLE,DISABLE
   21   1          if(CMPx->CMP_100nsFilter == DISABLE)    DISFLT = 1;     //内部0.1us滤波,    ENABLE,DISABLE
   22   1      
   23   1          if(CMPx->CMP_P_Select  <= CMP_P_ADC)    CMPEXCFG = (CMPEXCFG & ~0x03) | (CMPx->CMP_P_Select);       /
             -/比较器输入正极选择, CMP_P_P46/CMP_P_P50/CMP_P_P51, CMP_P_ADC: 由ADC模拟输入端做正输入.
   24   1          if(CMPx->CMP_N_Select  <= CMP_N_GAP)    CMPEXCFG = (CMPEXCFG & ~0x04) | (CMPx->CMP_N_Select << 2);  /
             -/比较器输入负极选择, CMP_N_GAP: 选择内部BandGap经过OP后的电压做负输入, CMP_N_P44: 选择P4.4做负输入.
   25   1      }


