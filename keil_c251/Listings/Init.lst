  362   2                      pin_mask = P_x;                         //              0101            P1.5                    1101            P0.5
  363   2                      pin_mask |= 0x08;                       //              0110            P1.6                    1110            P0.6
  364   2              }                                                               //              0111            P1.7                    1111            P0.7
