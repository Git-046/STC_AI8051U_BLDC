  357   1              {                                                               //              0000            P1.0                    1000            P0.0
  358   2                      pin_mask = P_x;                         //              0001            P1.1                    1001            P0.1
  359   2              }                                                               //              0010            P1.2                    1010            P0.2
  360   1              else if(Px_ == 0)       //P0.x          //              0011            P1.3                    1011            P0.3
