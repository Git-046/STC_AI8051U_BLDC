 1315          /*---------------------------------------------------------
 1316          @ function  :   char* strstr(const char* str1, const char* str2) 
 1317          @ describe  :   дкзжЗћДЎstr1жаВщевзгДЎstr2ЕФЮЛжУ
 1318          @ parameter :   str1: жїзжЗћДЎ    str2: вЊВщевЕФзгДЎ
 1319          @ date      :   2026-6-11
 1320          ----------------------------------------------------------*/
 1321          char* strstr(const char* str1, const char* str2) 
 1322          {
 1323   1              const char* p1;
 1324   1              const char* p1_adv;
 1325   1              const char* p2;
 1326   1              
 1327   1          if (*str2 == '\0') 
 1328   1                      return (char*)str1;
 1329   1        
 1330   1          p1 = str1;
 1331   1              
 1332   1          while (*p1) 
 1333   1              {
 1334   2              p1_adv = p1;
 1335   2              p2 = str2;
 1336   2              while (*p1_adv && *p2 && *p1_adv == *p2) 
 1337   2                      {
 1338   3                  p1_adv++;
 1339   3                  p2++;
 1340   3              }
 1341   2              
 1342   2              if (*p2 == '\0')
 1343   2                              return (char*)p1;
 1344   2              p1++;
C251 COMPILER V5.60.0,  Init                                                               12/06/26  11:09:40  PAGE 22  

 1345   2          } 
 1346   1          return NULL;
 1347   1      }
