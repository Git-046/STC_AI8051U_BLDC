  450          /*---------------------------------------------------------
  451          @ function  :   void PWM_Frequency_ARR_PSCR_Calculator(u32 set_freq, PWMx_InitDefine* PWMx_InitStructure)
  452          @ describe  :   ИљОнЩшЖЈЕФPWMЦЕТЪздЖЏМЦЫуARRКЭPSCRЕФжЕЃЌВЂХфжУЕНPWMГѕЪМЛЏНсЙЙЬхжа
  453          @ parameter :   set_freq: ЩшЖЈЕФPWMЦЕТЪ
  454                          PWMx_InitStructure: PWMГѕЪМЛЏНсЙЙЬхжИеыЃЌАќКЌPWMХфжУВЮЪ§
  455          @ date      :   2026-6-11
  456          ----------------------------------------------------------*/
  457          void PWM_Frequency_ARR_PSCR_Calculator(u32 set_freq, PWMx_InitDefine* PWMx_InitStructure)
  458          {
  459   1              /* жабыЖдЦыФЃЪНЕФPWMЦЕТЪЃКsystem_clock/((PSCR+1)*(ARR*2)) */
  460   1              /* БпдЕЖдЦыФЃЪНЕФPWMЦЕТЪЃКsystem_clock/((psc+1)*(arr+1)) */
  461   1              u32 period_cycles, frequency, pwm_clock_source;
  462   1              u16 arr, psc;
  463   1          
  464   1              pwm_clock_source = PWMA_SOURCE_FREQ;
  465   1              frequency = set_freq;
  466   1              if(frequency > pwm_clock_source || frequency <= 0)
  467   1              {
  468   2                      return;
  469   2              }
  470   1              period_cycles = pwm_clock_source / frequency;   //period_cycles = (psc+1)*(arr*2)
  471   1                                                                                                      //period_cycles = (psc+1)*(arr+1)
