  116          u16     Get_ADCResult(u8 channel)       //channel = 0~15
  117          {
  118   1              u16     adc;
  119   1              u8      i;
  120   1      
  121   1              if(channel > ADC_CH15)  return  4096;   //错误,返回4096,调用的程序判断  
  122   1              ADC_RES = 0;
  123   1              ADC_RESL = 0;
