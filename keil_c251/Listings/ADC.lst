   59          {
   60   1              u8 Px_ = (u8)atoi(ADC_InitStructure->ADC_Channel_Pin + 1);      //取引脚端口号
   61   1              u8 P_x = (u8)atoi(ADC_InitStructure->ADC_Channel_Pin + 3);      //取引脚位号
   62   1              u8 pin_mask = 0;        //配置寄存器的掩码
   63   1              if(Px_ == 1)            //P1.x          //      ADC_CONTR[3:0]  ADC通道         ADC_CONTR[3:0]  ADC通道
   64   1              {                                                               //              0000            P1.0                    1000            P0.0
   65   2                      pin_mask = P_x;                         //              0001            P1.1                    1001            P0.1
   66   2              }                                                               //              0010            P1.2                    1010            P0.2
   67   1              else if(Px_ == 0)       //P0.x          //              0011            P1.3                    1011            P0.3
   68   1              {                                                               //              0100            P1.4                    1100            P0.4
   69   2                      pin_mask = P_x;                         //              0101            P1.5                    1101            P0.5
   70   2                      pin_mask |= 0x08;                       //              0110            P1.6                    1110            P0.6
   71   2              }                                                               //              0111            P1.7                    1111            P0.7
   72   1              return pin_mask;        //返回ADC选择的通道引脚所对应的寄存器掩码 ADC_CONTR[3:0]
   73   1      }
