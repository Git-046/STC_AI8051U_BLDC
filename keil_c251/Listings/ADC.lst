   35          void ADC_Configuration(ADC_InitTypeDef* ADC_InitStructure)
   36          {
   37   1              //1. 打开ADC电源
   38   1              ADC_PowerControl(ENABLE);
   39   1              delay_ms(2);    //延时等待ADC电源稳定
   40   1              
   41   1              //2. 选择ADC采集引脚
   42   1              ADC_CONTR = (ADC_CONTR & ~0x0F) | ADC_Pin_Channel_Select(ADC_InitStructure);
   43   1              
   44   1              //3. 设置触发ADC采样的信号源
   45   1              if(ADC_InitStructure->ADC_PWMA_Triggle_EN == ENABLE)
   46   1              {
   47   2                      PWMA_CR2 = (PWMA_CR2 & ~0x70) | 0x20;   //PWMA更新周期事件为TRGO，用于周期触发ADC
   48   2              }
   49   1              else if(ADC_InitStructure->ADC_PWMB_Triggle_EN == ENABLE)
   50   1              {
   51   2                      PWMB_CR2 = (PWMB_CR2 & 0x70) | 0x20;    //PWMB更新周期事件为TRGO，用于周期触发ADC
   52   2              }
   53   1              
   54   1              //4. 配置数据对齐方式、ADC时钟、ADC时序
