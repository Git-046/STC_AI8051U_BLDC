   75          //========================================================================
   76          // 函数: u8     ADC_Inilize(ADC_InitTypeDef *ADCx)
   77          // 描述: ADC初始化程序.
   78          // 参数: ADCx: 结构参数,请参考adc.h里的定义.
   79          // 返回: none.
   80          // 版本: V1.0, 2012-10-22
   81          //========================================================================
   82          u8      ADC_Inilize(ADC_InitTypeDef *ADCx)
   83          {
   84   1              ADCCFG = (ADCCFG & ~ADC_SPEED_2X16T) | ADCx->ADC_Speed; //设置ADC工作时钟频率
   85   1              ADC_ALIGN_MODE(ADCx->ADC_Align_Mode);                                   //AD转换结果对齐方式
   86   1      
   87   1              if(ADCx->ADC_SMPduty > 31)      return FAIL;    //错误
   88   1              if(ADCx->ADC_CsSetup > 1)       return FAIL;    //错误
   89   1              if(ADCx->ADC_CsHold > 3)        return FAIL;    //错误
   90   1      
   91   1              ADCTIM = (ADCx->ADC_CsSetup << 7) | (ADCx->ADC_CsHold << 5) | ADCx->ADC_SMPduty ;//设置 ADC 内部时序，AD
             -C采样时间建议设最大值
   92   1              return SUCCESS;
   93   1      }
