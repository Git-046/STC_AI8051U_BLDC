   12          // КЏЪ§: u8     ADC_Inilize(ADC_InitTypeDef *ADCx)
   13          // УшЪі: ADCГѕЪМЛЏГЬађ.
   14          // ВЮЪ§: ADCx: НсЙЙВЮЪ§,ЧыВЮПМadc.hРяЕФЖЈвх.
   15          // ЗЕЛи: none.
   16          // АцБО: V1.0, 2012-10-22
   17          //========================================================================
   18          u8      ADC_Inilize(ADC_InitTypeDef *ADCx)
   19          {
   20   1              ADCCFG = (ADCCFG & ~ADC_SPEED_2X16T) | ADCx->ADC_Speed; //ЩшжУADCЙЄзїЪБжгЦЕТЪ
   21   1              ADC_ALIGN_MODE(ADCx->ADC_Align_Mode);                                   //ADзЊЛЛНсЙћЖдЦыЗНЪН
   22   1      
   23   1              if(ADCx->ADC_SMPduty > 31)      return FAIL;    //ДэЮѓ
   24   1              if(ADCx->ADC_CsSetup > 1)       return FAIL;    //ДэЮѓ
   25   1              if(ADCx->ADC_CsHold > 3)        return FAIL;    //ДэЮѓ
   26   1      
   27   1              ADCTIM = (ADCx->ADC_CsSetup << 7) | (ADCx->ADC_CsHold << 5) | ADCx->ADC_SMPduty ;//ЩшжУ ADC ФкВПЪБађЃЌAD
             -CВЩбљЪБМфНЈвщЩшзюДѓжЕ
   28   1              return SUCCESS;
   29   1      }
