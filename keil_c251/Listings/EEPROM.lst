   46          //========================================================================
   47          // 函数: void EEPROM_read_n(u32 EE_address,u8 *DataAddress,u16 number)
   48          // 描述: 从指定EEPROM首地址读出n个字节放指定的缓冲.
   49          // 参数: EE_address:  读出EEPROM的首地址.
   50          //       DataAddress: 读出数据放缓冲的首地址.
   51          //       number:      读出的字节长度.
   52          // 返回: non.
   53          // 版本: V1.0, 2012-10-22
   54          //========================================================================
   55          void EEPROM_read_n(u32 EE_address,u8 *DataAddress,u16 number)
   56          {
   57   1              IAP_ENABLE();                           //设置等待时间，允许IAP操作，送一次就够
   58   1              IAP_READ();                             //送字节读命令，命令不需改变时，不需重新送命令
C251 COMPILER V5.60.0,  EEPROM                                                             05/03/26  11:30:50  PAGE 2   

   59   1              do
   60   1              {
   61   2                      IAP_ADDRE = (u8)(EE_address >> 16); //送地址高字节（地址需要改变时才需重新送地址）
   62   2                      IAP_ADDRH = (u8)(EE_address >> 8);  //送地址中字节（地址需要改变时才需重新送地址）
   63   2                      IAP_ADDRL = (u8)EE_address;         //送地址低字节（地址需要改变时才需重新送地址）
   64   2                      EEPROM_Trig();                      //触发EEPROM操作
   65   2                      *DataAddress = IAP_DATA;            //读出的数据送往
   66   2                      EE_address++;
   67   2                      DataAddress++;
   68   2              }while(--number);
   69   1      
   70   1              DisableEEPROM();
   71   1      }
