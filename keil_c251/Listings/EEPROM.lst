   73          //========================================================================
   74          // 函数: void EEPROM_SectorErase(u32 EE_address)
   75          // 描述: 把指定地址的EEPROM扇区擦除.
   76          // 参数: EE_address:  要擦除的扇区EEPROM的地址.
   77          // 返回: non.
   78          // 版本: V1.0, 2013-5-10
   79          //========================================================================
   80          void EEPROM_SectorErase(u32 EE_address)
   81          {
   82   1              IAP_ENABLE();                       //设置等待时间，允许IAP操作，送一次就够
   83   1              IAP_ERASE();                        //宏调用, 送扇区擦除命令，命令不需改变时，不需重新送命令
   84   1                                                                                                                                                              //只有扇区擦除，没有字节擦除，512字节/扇区。
   85   1                                                                                                                                                              //扇区中任意一个字节地址都是扇区地址。
   86   1              IAP_ADDRE = (u8)(EE_address >> 16); //送扇区地址高字节（地址需要改变时才需重新送地址）
   87   1              IAP_ADDRH = (u8)(EE_address >> 8);  //送扇区地址中字节（地址需要改变时才需重新送地址）
   88   1              IAP_ADDRL = (u8)EE_address;         //送扇区地址低字节（地址需要改变时才需重新送地址）
   89   1              EEPROM_Trig();                      //触发EEPROM操作
   90   1              DisableEEPROM();                    //禁止EEPROM操作
   91   1      }
