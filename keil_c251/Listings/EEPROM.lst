   93          //========================================================================
   94          // 函数: void EEPROM_write_n(u32 EE_address,u8 *DataAddress,u16 number)
   95          // 描述: 把缓冲的n个字节写入指定首地址的EEPROM.
   96          // 参数: EE_address:  写入EEPROM的首地址.
   97          //       DataAddress: 写入源数据的缓冲的首地址.
   98          //       number:      写入的字节长度.
   99          // 返回: non.
  100          // 版本: V1.0, 2012-10-22
  101          //========================================================================
  102          void EEPROM_write_n(u32 EE_address,u8 *DataAddress,u16 number)
  103          {
  104   1              IAP_ENABLE();                       //设置等待时间，允许IAP操作，送一次就够
  105   1              IAP_WRITE();                        //宏调用, 送字节写命令
  106   1              do
  107   1              {
  108   2                      IAP_ADDRE = (u8)(EE_address >> 16); //送地址高字节（地址需要改变时才需重新送地址）
  109   2                      IAP_ADDRH = (u8)(EE_address >> 8);  //送地址中字节（地址需要改变时才需重新送地址）
  110   2                      IAP_ADDRL = (u8)EE_address;         //送地址低字节（地址需要改变时才需重新送地址）
  111   2                      IAP_DATA  = *DataAddress;         //送数据到IAP_DATA，只有数据改变时才需重新送
  112   2                      EEPROM_Trig();                    //触发EEPROM操作
  113   2                      EE_address++;                     //下一个地址
  114   2                      DataAddress++;                    //下一个数据
  115   2              }while(--number);                   //直到结束
  116   1              DisableEEPROM();
  117   1      }
